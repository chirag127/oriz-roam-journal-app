rules_version = '2';

// Firestore rules for oriz-journal — owner-only writes; no public reads.
// Mirrors the data shape documented in src/lib/types.ts.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function hasOnly(fields) { return request.resource.data.keys().hasOnly(fields); }

    // Profile doc lives at /users/{uid}.
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid)
        && hasOnly([
          'email','displayName','photoURL','isAnonymous',
          'createdAt','updatedAt',
          'defaultJournalType','timezone',
          'weatherEnabled','e2eeEnabled','e2eeSalt'
        ]);
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/entries/{entryId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && hasOnly([
          'title','body','bodyHtml',
          'mood','moodIntensity','tags',
          'journalType','entryDate',
          'createdAt','updatedAt',
          'favorite','pinned','isDraft',
          'wordCount','photoUrls','weather',
          'encrypted','encryptedNonce'
        ])
        && request.resource.data.title is string
        && request.resource.data.entryDate is string;
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/templates/{templateId} {
      allow read, write, delete: if isOwner(uid)
        && (request.method == 'delete' || hasOnly([
          'name','description','structure',
          'defaultJournalType','defaultMoodRequired',
          'isBuiltIn','createdAt','updatedAt'
        ]));
    }

    match /users/{uid}/tags/{tagId} {
      allow read, write, delete: if isOwner(uid)
        && (request.method == 'delete' || hasOnly([
          'name','color','count','createdAt'
        ]));
    }

    match /users/{uid}/goals/{goalId} {
      allow read, write, delete: if isOwner(uid)
        && (request.method == 'delete' || hasOnly([
          'title','description','type','target','progress',
          'period','startDate','endDate','completedAt',
          'isArchived','createdAt','updatedAt'
        ]));
    }

    match /users/{uid}/counters/{counterId} {
      allow read, write, delete: if isOwner(uid);
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
