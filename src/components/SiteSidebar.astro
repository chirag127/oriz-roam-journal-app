---
/**
 * Journal-specific sidebar with real routes (no longer pointing at /account/).
 * Sections per the rebuild brief:
 *   - Today        (Dashboard, New entry)
 *   - Browse       (Entries, Calendar, Memories, Search)
 *   - Organize     (Tags, Favorites, Pinned)
 *   - Insights     (Stats, Goals)
 *   - Setup        (Templates, Settings)
 *   - Family       (FAMILY_SITES quick-jump)
 */
import { Sidebar } from '@chirag127/oriz-ui'
import { FAMILY_SITES } from '@chirag127/oriz-ui'
import { SITE_CONFIG } from '~/lib/siteConfig'

const path = Astro.url.pathname.replace(/\/$/, '') || '/'
const here = (p: string) => path === p || path.startsWith(p + '/')

const sections = [
  {
    title: 'Today',
    links: [
      { label: '🏠 Dashboard', href: '/dashboard', active: here('/dashboard') },
      { label: '✍️ New entry', href: '/entries/new', active: path === '/entries/new' },
    ],
  },
  {
    title: 'Browse',
    links: [
      { label: '📚 Entries', href: '/entries', active: path === '/entries' || path.startsWith('/entries/') && path !== '/entries/new' },
      { label: '🗓️ Calendar', href: '/calendar', active: here('/calendar') },
      { label: '🌟 Memories', href: '/memories', active: here('/memories') },
      { label: '🔎 Search', href: '/search', active: here('/search') },
    ],
  },
  {
    title: 'Organize',
    links: [
      { label: '🏷️ Tags', href: '/tags', active: here('/tags') },
      { label: '❤️ Favorites', href: '/favorites', active: here('/favorites') },
      { label: '📌 Pinned', href: '/pinned', active: here('/pinned') },
    ],
  },
  {
    title: 'Insights',
    links: [
      { label: '📊 Stats', href: '/stats', active: here('/stats') },
      { label: '🎯 Goals', href: '/goals', active: here('/goals') },
    ],
  },
  {
    title: 'Setup',
    links: [
      { label: '📋 Templates', href: '/templates', active: here('/templates') },
      { label: '⚙️ Settings', href: '/settings', active: here('/settings') },
      { label: '👤 Account', href: '/account', active: here('/account') },
    ],
  },
  {
    title: 'Family',
    links: FAMILY_SITES
      .filter((s) => s.slug !== SITE_CONFIG.slug)
      .map((s) => ({ label: `${s.emoji} ${s.name}`, href: s.url })),
  },
]
---

<Sidebar
  client:idle
  siteName={SITE_CONFIG.name}
  siteSlug={SITE_CONFIG.slug}
  sections={sections}
/>
