---
/**
 * AppPage — wraps BaseLayout for signed-in app surfaces. Renders a page
 * heading + breadcrumb, and a slot for the React island. The island itself
 * is responsible for showing AuthGate when the user is not signed in.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'

interface Props {
  title: string
  description?: string
  heading?: string
  lede?: string
  noindex?: boolean
}

const { title, description, heading, lede, noindex = true } = Astro.props
---

<BaseLayout title={title} description={description} noindex={noindex}>
  <div class="app-page">
    {heading && (
      <header class="app-head">
        <h1>{heading}</h1>
        {lede && <p class="app-lede">{lede}</p>}
      </header>
    )}
    <slot />
  </div>

  <style>
    .app-page { padding: 1rem clamp(0.75rem, 3vw, 1.5rem) 4rem; max-width: 100%; }
    .app-head { padding-block: 1.25rem 0.5rem; margin-bottom: 0.5rem; }
    .app-head h1 { font-family: var(--font-serif); font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 600; letter-spacing: -0.01em; margin: 0; }
    .app-lede { color: var(--color-fg-muted); margin: 0.375rem 0 0; max-width: 56ch; }
  </style>
</BaseLayout>
