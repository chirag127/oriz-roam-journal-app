---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Offline — Journal" description="You are offline." showSidebar={false} noindex={true}>
  <section class="offline">
    <h1>You are offline.</h1>
    <p>Your last visited pages are still available below. New entries you write while offline will sync once you are back online.</p>
    <div class="off-actions">
      <a href="/dashboard" class="btn">Open dashboard</a>
      <a href="/entries" class="btn">Recent entries</a>
      <button type="button" id="off-retry" class="btn btn-primary">Try again</button>
    </div>
  </section>
  <script is:inline>
    document.getElementById('off-retry')?.addEventListener('click', () => location.reload())
  </script>
  <style>
    .offline { padding: 4rem 1.25rem; text-align: center; max-width: 56ch; margin: 0 auto; }
    .offline h1 { font-family: var(--font-serif); font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 1rem; }
    .offline p { color: var(--color-fg-muted); line-height: 1.6; }
    .off-actions { display: flex; gap: 0.625rem; justify-content: center; margin-top: 2rem; flex-wrap: wrap; }
    .btn { display: inline-flex; align-items: center; height: 40px; padding-inline: 1rem; border-radius: var(--radius-button); border: 1px solid var(--color-border); background: var(--color-bg-soft); color: var(--color-fg); text-decoration: none; cursor: pointer; font: inherit; font-size: 0.875rem; }
    .btn-primary { background: var(--color-accent); color: var(--color-accent-fg); border-color: var(--color-accent); }
  </style>
</BaseLayout>
