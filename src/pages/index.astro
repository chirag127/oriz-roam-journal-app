---
/*
 * Roam — v0 landing page.
 *
 * Replaces the v1/v2 "seal + ten-types" pitch. The new family aesthetic from
 * @chirag127/astro-shell takes over the chrome (top bar + footer); this page
 * is a single quiet hero + two short sections (v0 shipped, v0.1 next) on the
 * shared cream-paper canvas. No dashboard CTA, no feature grid, no "Coming
 * soon" — the page says what works today and what's next.
 */
import FamilyChrome from '@chirag127/astro-shell/components/FamilyChrome.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Roam',
  url: SITE_CONFIG.origin,
  description: 'A writing journal you actually return to.',
  publisher: { '@type': 'Person', name: 'Chirag Singhal' },
}

const title = 'Roam — a writing journal you actually return to'
const description = 'A privacy-first journal that meets you where you are: write a sentence, write a page, write nothing. The journal stays.'
const canonical = `${SITE_CONFIG.origin}${Astro.url.pathname}`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#faf6ef" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Roam — oriz" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@chirag127" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter+Tight:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <FamilyChrome slug="oriz-roam-journal-app" title="Roam" accent="#1a3a8f" />

    <main id="main">
      <section class="hero">
        <h1 class="hero__title">Roam</h1>
        <p class="hero__tagline">a writing journal you actually return to</p>
        <p class="hero__about">
          Most journals fail the same way: a strong week, a missed day, and
          the streak counter quietly turns into a shame engine. Roam takes
          the opposite stance — write a sentence, write a page, write
          nothing. The journal stays. Plaintext never leaves the device,
          sync is optional, and the writing surface is the only thing on
          the page.
        </p>
      </section>

      <hr class="rule" />

      <section class="block">
        <h2 class="block__h">v0 — what&rsquo;s shipped</h2>
        <ul class="block__list">
          <li>
            Sign in works (shared <code>oriz_auth</code> cookie across every
            <code>*.oriz.in</code> app) and pricing works (single Razorpay
            checkout on oriz.in). More coming.
          </li>
        </ul>
      </section>

      <hr class="rule" />

      <section class="block">
        <h2 class="block__h">v0.1 — what&rsquo;s next</h2>
        <ul class="block__list">
          <li>
            Tiptap editor with the cream-paper writing surface — 66 characters
            per line, no toolbar in the way, autosave to IndexedDB.
          </li>
          <li>
            libsodium-sealed entries — encrypted at rest on the device,
            seal status visible on every page.
          </li>
          <li>
            Daily view + month calendar — jump to a date, see what you wrote
            a year ago, no streak counters, no flame icons.
          </li>
          <li>
            Optional Firestore sync for signed-in users — encrypted blobs only;
            the server never sees plaintext.
          </li>
          <li>
            Tag &amp; full-text search across local entries, plus an export-everything
            button (Markdown zip) so the journal is always yours.
          </li>
        </ul>
      </section>

      <hr class="rule" />

      <p class="track">
        <a href="https://github.com/oriz-co/oriz-roam-journal-app">Track development &rarr;</a>
      </p>
    </main>

    <style is:global>
      html, body {
        margin: 0;
        padding: 0;
        background: #faf6ef;
        color: #15140f;
        font-family: 'Inter Tight', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .skip-link {
        position: absolute;
        left: -9999px;
      }
      .skip-link:focus {
        left: 16px;
        top: 16px;
        background: #15140f;
        color: #faf6ef;
        padding: 8px 12px;
        z-index: 200;
      }
    </style>

    <style>
      main {
        max-width: 720px;
        margin: 0 auto;
        padding: clamp(2.5rem, 6vw, 5rem) 20px clamp(2rem, 5vw, 4rem);
      }
      .hero {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .hero__title {
        font-family: 'Fraunces', Georgia, serif;
        font-weight: 600;
        font-size: clamp(3rem, 9vw, 5.5rem);
        letter-spacing: -0.02em;
        line-height: 0.95;
        margin: 0;
        color: #15140f;
      }
      .hero__tagline {
        font-family: 'Inter Tight', system-ui, sans-serif;
        font-size: clamp(1.0625rem, 2.2vw, 1.25rem);
        color: #1a3a8f;
        margin: 0;
        font-weight: 500;
        letter-spacing: -0.005em;
      }
      .hero__about {
        font-family: 'Inter Tight', system-ui, sans-serif;
        font-size: 1.0625rem;
        line-height: 1.65;
        color: #3a3a36;
        max-width: 60ch;
        margin: 0.75rem 0 0;
      }

      .rule {
        border: 0;
        border-top: 1px solid #15140f;
        margin: 3rem 0;
      }

      .block__h {
        font-family: 'Fraunces', Georgia, serif;
        font-weight: 600;
        font-size: 1.5rem;
        letter-spacing: -0.01em;
        margin: 0 0 1rem;
        color: #15140f;
      }
      .block__list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
      }
      .block__list li {
        font-size: 1rem;
        line-height: 1.6;
        color: #3a3a36;
        padding-left: 1.25rem;
        position: relative;
      }
      .block__list li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.7em;
        width: 6px;
        height: 1px;
        background: #15140f;
      }
      .block__list code {
        font-family: ui-monospace, 'SF Mono', Menlo, monospace;
        font-size: 0.875em;
        background: #efe9d8;
        padding: 0.05em 0.35em;
        color: #15140f;
      }

      .track {
        margin: 2rem 0 0;
        font-size: 0.9375rem;
      }
      .track a {
        color: #1a3a8f;
        text-decoration: none;
        border-bottom: 1px solid #1a3a8f;
        padding-bottom: 1px;
      }
      .track a:hover {
        background: #1a3a8f;
        color: #faf6ef;
      }

      @media (max-width: 640px) {
        main { padding-inline: 18px; }
        .hero__about { font-size: 1rem; }
        .rule { margin: 2.25rem 0; }
      }
    </style>
  </body>
</html>
